rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /orders/{orderId} {
      // Allow anyone to create an order
      allow create: if true;
      // Only the admin can read, update, or delete orders
      allow read, update, delete: if request.auth != null && request.auth.token.email == "heroeducation72@gmail.com";
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "heroeducation72@gmail.com";
    }

    match /public_data/{docId} {
      // Anyone can read public config (like images)
      allow read: if true;
      // Only admin can upload/change images
      allow write: if request.auth != null && request.auth.token.email == "heroeducation72@gmail.com";
    }
  }
}
